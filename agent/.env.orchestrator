# llama-server (sourced by scripts/run-llama-server.sh)
# See also: BINARY_PATH, MODEL_PATH, PROJ_PATH, PORT

NGL=99
CTX_SIZE=4096
BATCH=1024
PREDICT=1024
THREADS=8

TEMP=1.0
TOP_P=0.95
TOP_K=64

JINJA=1
FLASH_ATTN=on
CNV=1
MLOCK=0

# Python orchestrator (unquoted; GRPC_TIMEOUT_S in seconds, e.g. 4.0)
LLAMA_CPP_URL=http://127.0.0.1:8080
MODEL_NAME=gemma
GRPC_TARGET=192.168.4.1:50051
GRPC_TIMEOUT_S=4.0
