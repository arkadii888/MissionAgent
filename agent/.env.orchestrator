# Optional: override defaults from agent/scripts/run-llama-server.sh
# (defaults: llama.cpp build under this repo, models under agent/models/)
# BINARY_PATH=/path/to/llama-server
# MODEL_PATH=/path/to/model.gguf
# PROJ_PATH=/path/to/mmproj.gguf
# Port default is 8080 (agent/scripts/run-llama-server.sh). Set on the command line, e.g. PORT=18090

NGL=99
CTX_SIZE=4096
BATCH=1024
PREDICT=1024
THREADS=8

TEMP=1.0
TOP_P=0.95
TOP_K=64

JINJA=1
FLASH_ATTN=on
CNV=1
MLOCK=0
